{
	"compilerOptions": {
    "moduleResolution": "node16",
    "module": "node16",
    "target": "es2020",
		"lib": ["esnext"],
		"outDir": "out",
		"rootDir": "src",
		"sourceMap": true,
		"resolveJsonModule": true,
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": ["node_modules", ".vscode-test"]
}

